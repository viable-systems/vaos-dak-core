{
  "name": "@vaos/dak-core",
  "version": "0.2.0",
  "description": "Deterministic autonomy kernel primitives for VAOS",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/viable-systems/vaos-dak-core.git"
  },
  "bugs": {
    "url": "https://github.com/viable-systems/vaos-dak-core/issues"
  },
  "homepage": "https://github.com/viable-systems/vaos-dak-core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "dak": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --splitting false --tsconfig tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:determinism": "vitest run tests/ledger.test.ts tests/reducer.test.ts tests/tick-engine.test.ts tests/proof-receipt.test.ts",
    "cli": "node ./dist/cli.js",
    "benchmark": "tsx benchmarks/tick-replay.bench.ts 1000",
    "benchmark:ci": "tsx benchmarks/tick-replay.bench.ts 5000 > docs/benchmarks/latest.json",
    "verify:script": "tsx scripts/verify-ledger.ts",
    "replay:script": "tsx scripts/replay-ledger.ts",
    "audit:script": "tsx scripts/audit-ledger.ts",
    "prepublishOnly": "npm run typecheck && npm run test:determinism && npm run build",
    "dogfood:supabase": "tsx scripts/ci/supabase-dogfood.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
